# 1️⃣ 安装 BiocManager（如果没有）
install.packages("BiocManager")
# 2️⃣ 安装 edgeR
BiocManager::install("edgeR")
library(edgeR)
group <- coldata$condition
y <- DGEList(counts = counts, group = group)
# 2️⃣ 过滤低表达
keep <- filterByExpr(y)
y <- y[keep,,keep.lib.sizes=FALSE]
# 3️⃣ 归一化
y <- calcNormFactors(y)
# 4️⃣ 估计离散度
y <- estimateDisp(y)
# 5️⃣ exact test
et <- exactTest(y)
# 6️⃣ 获取所有结果（⚠️ 重点：不是 n=1000）
summary(de <- decideTestsDGE(et))
# 👉 关键：确保拿到所有gene
n_genes <- nrow(y)
diffExpGenes <- topTags(et, n = n_genes)
# 保存
write.csv(diffExpGenes$table, "edgeR_DE_results.csv")
############################################
# 1. 读入 counts 数据
############################################
counts <- read.table("../4counts/counts.txt",
                     header=TRUE,
                     row.names=1,
                     comment.char="#")
# 去掉前5列（featureCounts格式）
counts <- counts[,6:ncol(counts)]
############################################
# 2. 样本分组（⚠️ 这里一定要改！）
############################################
# 👉 根据你的样本顺序修改
# 举例：5个 lymphnode + 4个 spleen
coldata <- data.frame(
  row.names = colnames(counts),
  condition = c(
    rep("lymphnode", 5),
    rep("spleen", 4)
  )
)
############################################
# 3. 创建 DESeq2 对象 + 归一化
############################################
dds <- DESeqDataSetFromMatrix(
  countData = counts,
  colData = coldata,
  design = ~ condition
)
# 去低表达（推荐）
dds <- dds[rowSums(counts(dds)) > 10, ]
# VST转换（用于可视化）
vsd <- vst(dds, blind=TRUE)
############################################
# 4. PCA（样本关系）
############################################
pdf("PCA_plot.pdf")
plotPCA(vsd, intgroup="condition")
dev.off()
############################################
# 5. Sample distance heatmap（聚类）
############################################
# 当前列名
# 去掉前面的路径（到 3align. 为止）
colnames(counts) <- sub(".*3align\\.", "", colnames(counts))
# 去掉结尾 .s.bam
colnames(counts) <- sub("\\.s\\.bam$", "", colnames(counts))
colnames(counts)
# 2️⃣ 重新建 coldata
condition <- ifelse(
  grepl("lymphnode", colnames(counts)),
  "lymphnode",
  "spleen"
)
coldata <- data.frame(
  row.names = colnames(counts),
  condition = factor(condition)
)
# 3️⃣ 重新建 DESeq2 对象
dds <- DESeqDataSetFromMatrix(
  countData = counts,
  colData = coldata,
  design = ~ condition
)
dds <- dds[rowSums(counts(dds)) > 10, ]
# 4️⃣ 重新做 vst
vsd <- vst(dds, blind=TRUE)
# 5️⃣ 重新算距离
sampleDists <- dist(t(assay(vsd)))
# 6️⃣ 再画图
pdf("Sample_distance_heatmap.pdf")
pheatmap(
  as.matrix(sampleDists),
  annotation_col = coldata
)
dev.off()
############################################
# 6. 基因表达 heatmap（Top variable genes）
############################################
topVarGenes <- head(order(rowVars(assay(vsd)), decreasing=TRUE), 10)
mat <- assay(vsd)[topVarGenes, ]
mat <- mat - rowMeans(mat)
pdf("3Top10_genes_heatmap.pdf")
pheatmap(
  mat,
  annotation_col = coldata,
  show_rownames = TRUE
)
dev.off()
############################################
# 7. 差异表达分析（DESeq2）
############################################
dds <- DESeq(dds)
res <- results(dds)
# 排序
res <- res[order(res$padj), ]
# 保存结果
write.csv(as.data.frame(res), "DE_results.csv")
############################################
# 8. Volcano plot
############################################
res_df <- as.data.frame(res)
# 去掉NA
library(ggrepel)
# 去掉NA
res_df <- res_df[!is.na(res_df$padj), ]
threshold_p <- 0.01
threshold_fc <- 4
res_df$significant <- res_df$padj < threshold_p & abs(res_df$log2FoldChange) > threshold_fc
# 选 top 10（按 padj 最小a）
top_genes <- head(res_df[order(res_df$padj), ], 10)
pdf("Volcano_plot.pdf")
ggplot(res_df, aes(x=log2FoldChange, y=-log10(padj), color=significant)) +
  geom_point(alpha=0.6, size=1) +
  scale_color_manual(values=c("grey","red")) +
  geom_hline(yintercept=-log10(threshold_p), linetype="dashed") +
  geom_vline(xintercept=c(-log2(threshold_fc),log2(threshold_fc)), linetype="dashed") +
  geom_text_repel(
    data = top_genes,
    aes(label = rownames(top_genes)),
    size = 3,
    max.overlaps = 100
  ) +
  theme_minimal()
dev.off()
############################################
# 9. Differential Expression (edgeR)
############################################
library(edgeR)
# 1️⃣ 构建 DGEList
group <- coldata$condition
y <- DGEList(counts = counts, group = group)
# 2️⃣ 过滤低表达
keep <- filterByExpr(y)
y <- y[keep,,keep.lib.sizes=FALSE]
# 3️⃣ 归一化
y <- calcNormFactors(y)
# 4️⃣ 估计离散度
y <- estimateDisp(y)
# 5️⃣ exact test
et <- exactTest(y)
# 6️⃣ 获取所有结果（⚠️ 重点：不是 n=1000）
summary(de <- decideTestsDGE(et))
# 👉 关键：确保拿到所有gene
n_genes <- nrow(y)
diffExpGenes <- topTags(et, n = n_genes)
# 保存
write.csv(diffExpGenes$table, "edgeR_DE_results.csv")
write.csv(diffExpGenes$table, "edgeR_DE_results.csv")
