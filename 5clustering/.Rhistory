group <- coldata$condition
y <- DGEList(counts = counts, group = group)
# 1️⃣ 过滤低表达
keep <- filterByExpr(y)
y <- y[keep,,keep.lib.sizes=FALSE]
# 2️⃣ 归一化
y <- calcNormFactors(y)
# 3️⃣ 估计离散度
y <- estimateDisp(y)
# 4️⃣ exact test
et <- exactTest(y)
# 5️⃣ 获取所有基因（⚠️ 先做这个！）
n_genes <- nrow(y)
diffExpGenes <- topTags(et, n = n_genes)
# 6️⃣ 提取结果表
edgeR_df <- diffExpGenes$table
# 7️⃣ 统计显著基因
padj_cutoff <- 0.05
fc_cutoff <- 1
sig <- edgeR_df$FDR < padj_cutoff
up <- sum(sig & edgeR_df$logFC > fc_cutoff)
down <- sum(sig & edgeR_df$logFC < -fc_cutoff)
cat("Upregulated:", up, "\n")
cat("Downregulated:", down, "\n")
# 8️⃣ 保存结果
write.csv(edgeR_df, "edgeR_DE_results.csv")
q()
