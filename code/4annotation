library(dplyr)

summary_df <- df_long %>%
  group_by(group, variable) %>%
  summarise(mean = mean(value), .groups = "drop")
pvals <- df_long %>%
  group_by(variable) %>%
  summarise(
    p = wilcox.test(value ~ group)$p.value,
    .groups = "drop"
  )
# ⭐ 转星号函数
pvals$stars <- cut(
  pvals$p,
  breaks = c(-Inf, 0.001, 0.01, 0.05, Inf),
  labels = c("***", "**", "*", "")
)
############################################
# 3️⃣ 计算标注位置（放在柱子上方）
############################################
pos <- summary_df %>%
  group_by(variable) %>%
  summarise(y = max(mean) * 1.1)
pvals <- merge(pvals, pos, by = "variable")
############################################
# 4️⃣ 作图 + 加星号
############################################
ggplot(summary_df, aes(x = variable, y = mean, fill = group)) +
  geom_bar(stat = "identity", position = position_dodge(width = 0.8), width = 0.8) +
  
  # ⭐ 星号
  geom_text(
    data = pvals,
    aes(x = variable, y = y, label = stars),
    inherit.aes = FALSE,
    size = 5
  ) +
  
  theme_minimal() +
  labs(
    x = "Cell Type",
    y = "Mean proportion",
    fill = "Group",
    title = "Cell Type Comparison with Significance"
  ) +
  scale_fill_manual(values = c(
    "lymphnode" = "#4DBBD5",
    "spleen" = "#E64B35"
  ))+
  theme(axis.text.x = element_text(angle = 45, hjust = 1),
        panel.grid.major = element_blank(),
        panel.grid.minor = element_blank(),
        axis.line = element_line(color = "black"),
        plot.title = element_text(hjust = 0.5, size = 16, face = "bold"))
