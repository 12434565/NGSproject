df <- read.csv("CIBERSORTx_Job4_Results.csv", row.names = 1)
group <- ifelse(grepl("lymphnode", rownames(df)), "lymphnode", "spleen")
pvals <- c()

for (cell in colnames(df)) {
  x <- df[group == "lymphnode", cell]
  y <- df[group == "spleen", cell]
  
  test <- wilcox.test(x, y)  # 推荐
  pvals[cell] <- test$p.value
}

# 多重校正
padj <- p.adjust(pvals, method = "BH")

res <- data.frame(
  CellType = names(pvals),
  pvalue = pvals,
  padj = padj
)

# 排序
res <- res[order(res$padj), ]
head(res)

