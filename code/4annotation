library(ggplot2)
library(ggpubr)
library(patchwork)

cell_types <- unique(df_long$variable)

plot_list <- lapply(cell_types, function(ct) {
  
  df_sub <- df_long[df_long$variable == ct, ]
  
  ggplot(df_sub, aes(x = group, y = value, fill = group)) +
    geom_boxplot(outlier.shape = NA, width = 0.5) +
    
    geom_jitter(width = 0.1, alpha = 0.6, size = 1.2) +
    
    stat_compare_means(
      method = "wilcox.test",
      label = "p.signif",
      hide.ns = TRUE
    ) +
    
    scale_fill_manual(values = c(
      "lymphnode" = "#4DBBD5",
      "spleen" = "#E64B35"
    )) +
    
    theme_minimal() +
    theme(
      aspect.ratio = 1,  # ⭐ 变高
      panel.border = element_rect(color = "black", fill = NA),
      plot.title = element_text(hjust = 0.5),
      legend.position = "none"
    ) +
    
    labs(
      title = ct,
      x = "",
      y = "Proportion"
    )
})

# 🔥 拼图
combined_plot <- wrap_plots(plot_list, ncol = 6)

