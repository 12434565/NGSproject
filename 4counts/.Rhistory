df <- read.csv("CIBERSORTx_Job4_Results.csv", row.names = 1)
group <- ifelse(grepl("lymphnode", rownames(df)), "lymphnode", "spleen")
pvals <- c()
for (cell in colnames(df)) {
  x <- df[group == "lymphnode", cell]
  y <- df[group == "spleen", cell]

  test <- wilcox.test(x, y)  # 推荐
  pvals[cell] <- test$p.value
}

# 多重校正
padj <- p.adjust(pvals, method = "BH")

res <- data.frame(
  CellType = names(pvals),
  pvalue = pvals,
  padj = padj
)

# 排序
res <- res[order(res$padj), ]
head(res)

library(ggplot2)
library(reshape2)
df$group <- ifelse(grepl("lymphnode", rownames(df)), "lymphnode", "spleen")
# 转长格式
df <- df[, !colnames(df) %in% c("P.value", "Correlation", "RMSE")]

df_long <- melt(df, id.vars = "group")

# 加 sample 名
df_long$sample <- rep(rownames(df), times = ncol(df)-1)

# 画图

p <- ggplot(df_long, aes(x = sample, y = value, fill = variable)) +
  geom_bar(stat = "identity") +
  theme_minimal() +
  labs(
    x = "Sample",
    y = "Cell proportion",
    fill = "Cell Type",
    title = "Immune Cell Composition (CIBERSORTx)"
  ) +
  theme(
    axis.text.x = element_text(angle = 45, hjust = 1)
  )
ggsave("cell_composition.png", plot = p, width = 10, height = 6, dpi = 300)


library(dplyr)

summary_df <- df_long %>%
  group_by(group, variable) %>%
  summarise(mean = mean(value), .groups = "drop")
pvals <- df_long %>%
  group_by(variable) %>%
  summarise(
    p = wilcox.test(value ~ group)$p.value,
    .groups = "drop"
  )
# ⭐ 转星号函数
pvals$stars <- cut(
  pvals$p,
  breaks = c(-Inf, 0.001, 0.01, 0.05, Inf),
  labels = c("***", "**", "*", "")
)
############################################
# 3️⃣ 计算标注位置（放在柱子上方）
############################################
pos <- summary_df %>%
  group_by(variable) %>%
  summarise(y = max(mean) * 1.1)
pvals <- merge(pvals, pos, by = "variable")
############################################
# 4️⃣ 作图 + 加星号
############################################
p <- ggplot(summary_df, aes(x = variable, y = mean, fill = group)) +
  geom_bar(stat = "identity", position = position_dodge(width = 0.8), width = 0.8) +
  
  # ⭐ 星号
  geom_text(
    data = pvals,
    aes(x = variable, y = y, label = stars),
    inherit.aes = FALSE,
    size = 5
  ) +
  
  theme_minimal() +
  labs(
    x = "Cell Type",
    y = "Mean proportion",
    fill = "Group",
    title = "Cell Type Comparison with Significance"
  ) +
  scale_fill_manual(values = c(
  "lymphnode" = "#4DBBD5",
  "spleen" = "#E64B35"
))+
  theme(axis.text.x = element_text(angle = 45, hjust = 1),
        panel.grid.major = element_blank(),
        panel.grid.minor = element_blank(),
        axis.line = element_line(color = "black"))
# 保存
ggsave("cell_type_with_stars.png", p, width = 15, height = 6, dpi = 300)
