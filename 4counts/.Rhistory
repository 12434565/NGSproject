library(ggplot2)
library(reshape2)

# 加 group
df$group <- ifelse(grepl("lymphnode", rownames(df)), "lymphnode", "spleen")
df <- df[, colSums(df != 0) > 0]
# 转长格式
df <- df[, !colnames(df) %in% c("P.value", "Correlation", "RMSE")]

df_long <- melt(df, id.vars = "group")

# 加 sample 名
df_long$sample <- rep(rownames(df), times = ncol(df)-1)

# 画图

p <- ggplot(df_long, aes(x = sample, y = value, fill = variable)) +
  geom_bar(stat = "identity") +
  theme_minimal() +
  labs(
    x = "Sample",
    y = "Cell proportion",
    fill = "Cell Type",
    title = "Immune Cell Composition (CIBERSORTx)"
  ) +
  theme(
    axis.text.x = element_text(angle = 45, hjust = 1)
  )
ggsave("cell_composition.png", plot = p, width = 10, height = 6, dpi = 300)


library(dplyr)

